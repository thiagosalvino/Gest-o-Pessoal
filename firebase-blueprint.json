{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role (admin can see everything)" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "blocked", "inactive"], "description": "User approval status" },
        "displayName": { "type": "string", "description": "User display name" },
        "birthDate": { "type": "string", "description": "User date of birth" },
        "cpf": { "type": "string", "description": "User CPF" },
        "phone": { "type": "string", "description": "User phone number" },
        "createdAt": { "type": "string", "description": "Registration date" },
        "lastLogin": { "type": "string", "description": "Last login date" }
      },
      "required": ["uid", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "A task to be completed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string", "description": "Owner of the task" }
      },
      "required": ["id", "title", "completed", "userId"]
    },
    "Project": {
      "title": "Project",
      "description": "A project containing goals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "userId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Calendar appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "category": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "date", "time", "category", "userId"]
    },
    "MealEntry": {
      "title": "MealEntry",
      "description": "Diet meal entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dayOfWeek": { "type": "integer" },
        "type": { "type": "string" },
        "time": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "dayOfWeek", "type", "time", "userId"]
    },
    "TrainingEntry": {
      "title": "TrainingEntry",
      "description": "Training entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dayOfWeek": { "type": "integer" },
        "type": { "type": "string" },
        "time": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "dayOfWeek", "type", "time", "userId"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A goal within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "projectId": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "projectId", "userId"]
    },
    "PomodoroSession": {
      "title": "PomodoroSession",
      "description": "A timed focus session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "classification": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "classification", "status", "createdAt"]
    },
    "NotificationSettings": {
      "title": "NotificationSettings",
      "description": "User notification preferences",
      "type": "object",
      "properties": {
        "browserNotificationsEnabled": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["browserNotificationsEnabled", "userId"]
    },
    "StandardAlert": {
      "title": "StandardAlert",
      "description": "Recurring alerts independent of the calendar",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "cycleMinutes": { "type": "number" },
        "duration": { "type": "string", "enum": ["every_day", "only_today"] },
        "startDateTime": { "type": "string" },
        "endDateTime": { "type": "string" },
        "lastTriggeredAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["description", "cycleMinutes", "duration", "startDateTime", "endDateTime", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks collection"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects collection"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments collection"
    },
    "/diet/{mealId}": {
      "schema": "MealEntry",
      "description": "Diet entries"
    },
    "/training/{trainingId}": {
      "schema": "TrainingEntry",
      "description": "Training entries"
    },
    "/standardAlerts/{alertId}": {
      "schema": "StandardAlert",
      "description": "Standard alerts collection"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Goals collection"
    },
    "/pomodoroSessions/{sessionId}": {
      "schema": "PomodoroSession",
      "description": "Pomodoro sessions"
    },
    "/settings/{userId}": {
      "schema": "NotificationSettings",
      "description": "User notification settings"
    },
    "/cpfs/{cpf}": {
      "schema": "object",
      "description": "CPF uniqueness mapping"
    }
  }
}
