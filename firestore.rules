rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, displayName
    //
    // Collection: tasks
    // Fields: id, title, completed, userId
    //
    // Collection: projects
    // Fields: id, title, description, userId
    //
    // Collection: appointments
    // Fields: id, title, date, time, category, userId
    //
    // Collection: diet
    // Fields: id, dayOfWeek, type, time, userId
    //
    // Collection: training
    // Fields: id, dayOfWeek, type, time, userId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "thiagosalvinots2020@gmail.com" ||
         request.auth.token.email == "administrador@app.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Rules for users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Generic rules for user-owned data
    match /{collection}/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
