rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, displayName
    //
    // Collection: tasks
    // Fields: id, title, completed, userId
    //
    // Collection: projects
    // Fields: id, title, description, userId
    //
    // Collection: appointments
    // Fields: id, title, date, time, category, userId
    //
    // Collection: diet
    // Fields: id, dayOfWeek, type, time, userId
    //
    // Collection: training
    // Fields: id, dayOfWeek, type, time, userId
    //
    // Collection: standardAlerts
    // Fields: description, cycleMinutes, duration, startDateTime, endDateTime, userId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidStandardAlert(data) {
      return data.description is string && data.description.size() > 0 && data.description.size() < 200 &&
             data.cycleMinutes is number && data.cycleMinutes > 0 &&
             data.duration in ['every_day', 'only_today'] &&
             data.startDateTime is string &&
             data.endDateTime is string &&
             data.userId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "thiagosalvinots2020@gmail.com" ||
         request.auth.token.email == "administrador@app.com" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Rules for users collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Rules for settings collection
    match /settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Rules for standardAlerts collection
    match /standardAlerts/{alertId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidStandardAlert(request.resource.data);
      allow update: if (isOwner(resource.data.userId) || isAdmin()) && isValidStandardAlert(request.resource.data);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Generic rules for user-owned data
    match /{collection}/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
