rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, displayName, birthDate, cpf, phone
    //
    // Collection: tasks
    // Fields: id, title, completed, userId
    //
    // Collection: projects
    // Fields: id, title, description, userId
    //
    // Collection: appointments
    // Fields: id, title, date, time, category, userId
    //
    // Collection: diet
    // Fields: id, dayOfWeek, type, time, userId
    //
    // Collection: training
    // Fields: id, dayOfWeek, type, time, userId
    //
    // Collection: standardAlerts
    // Fields: description, cycleMinutes, duration, startDateTime, endDateTime, userId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidStandardAlert(data) {
      return data.description is string && data.description.size() > 0 && data.description.size() < 200 &&
             data.cycleMinutes is number && data.cycleMinutes > 0 &&
             data.duration in ['every_day', 'only_today'] &&
             data.startDateTime is string &&
             data.endDateTime is string &&
             data.userId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "thiagosalvinots2020@gmail.com" ||
          request.auth.token.email == "administrador@app.com") && 
          request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string &&
             (!('birthDate' in data) || data.birthDate is string) &&
             (!('cpf' in data) || data.cpf is string) &&
             (!('phone' in data) || data.phone is string) &&
             data.role in ['admin', 'user'] &&
             data.status in ['pending', 'approved', 'rejected', 'blocked', 'inactive'];
    }

    // Rules for cpfs collection (for uniqueness checks)
    match /cpfs/{cpf} {
      allow get: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Rules for users collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      (request.resource.data.role == 'user' || 
                       request.auth.token.email == "thiagosalvinots2020@gmail.com" ||
                       request.auth.token.email == "administrador@app.com" ||
                       isAdmin()) &&
                      (request.resource.data.status == 'pending' || 
                       request.auth.token.email == "thiagosalvinots2020@gmail.com" ||
                       request.auth.token.email == "administrador@app.com" ||
                       isAdmin());
      allow update: if (isOwner(userId) && 
                        isValidUser(request.resource.data) &&
                        request.resource.data.role == resource.data.role &&
                        request.resource.data.status == resource.data.status) || 
                       isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for settings collection
    match /settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Rules for standardAlerts collection
    match /standardAlerts/{alertId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidStandardAlert(request.resource.data);
      allow update: if (isOwner(resource.data.userId) || isAdmin()) && isValidStandardAlert(request.resource.data);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Generic rules for user-owned data
    match /{collection}/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
